{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "npm *": "allow",
      "rm *": "deny",
      "grep *": "allow"
    },
    "read": "allow",
    "list": "allow",
    "glob": "allow",
    "edit": {
      "*": "deny",
      "/home/opencode/projects": "ask"
    }
  },
  "provider": {
    "gpt2giga": {
      "name": "gpt2giga",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://100.114.142.48:8090"
      },
      "models": {
        "GigaChat": {
          "name": "GigaChat"
        }
      }
    },
    "elvees_deepseek": {
      "name": "elvees_deepseek",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://cv7gpufarm:8001/v1"
      },
      "models": {
        "/models/DeepSeek-Coder": {
          "name": "DeepSeek-Coder",
          "tool_call": false
        }
      }
    },
    "elvees_qween": {
      "name": "elvees_qween",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://cv7gpufarm:8001/v1"
      },
      "models": {
        "/models/Qwen3-Coder": {
          "name": "Qwen3-Coder"
        }
      }
    }
  },
  "agent": {
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "mode": "subagent",
      "model": "/models/Qwen3-Coder",
      "prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
      "tools": {
        "write": false,
        "edit": false
      }
    }
  }
}

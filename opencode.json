{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "list": "allow",
    "glob": "allow",
    "read": {
      "*": "allow",
      "~/**/.env": "deny",
      "**/.env": "deny",
      "~/**/.ssh/**": "deny",
      "**/.ssh/**": "deny",
      "~/**/.gnupg/**": "deny",
      "**/.gnupg/**": "deny"
    },
    "edit": {
      "*": "ask",
      "~/dotfiles/**": "allow",
      "~/dotfiles/.git/**": "deny",
      "~/**/.env": "deny",
      "**/.env": "deny",
      "~/**/.ssh/**": "deny",
      "**/.ssh/**": "deny"
    },
    "write": {
      "*": "ask",
      "~/dotfiles/**": "allow",
      "~/**/.env": "deny",
      "**/.env": "deny",
      "~/**/.ssh/**": "deny",
      "**/.ssh/**": "deny"
    },
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "cat *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show *": "allow"
    },
    "webfetch": "ask"
  },
  "agent": {
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": {
        "read": "allow",
        "edit": "deny",
        "write": "deny",
        "webfetch": "deny",
        "bash": {
          "*": "deny",
          "git diff *": "allow",
          "git log *": "allow",
          "git show *": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "cat *": "allow"
        }
      },
      "prompt": "You are a code reviewer. Focus on security, performance, and maintainability."
    }
  }
}
